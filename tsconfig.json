{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": ".",
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/pico/runtime_vertical_slice/tools/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
